# Copia este archivo como .env y completa los valores

# URL de conexión a la base de datos PostgreSQL (de Supabase o Render)
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db

# Clave secreta para sesiones (cualquier texto largo y aleatorio)
SESSION_SECRET=cambia-esto-por-algo-secreto-y-largo

# Puerto del servidor (Render lo asigna automáticamente)
PORT=3000

# Entorno
NODE_ENV=production
